# Local MySQL (used only for one-time migration from XAMPP)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ioorganize

# Supabase Postgres connection URI (Session pooler recommended)
DATABASE_URL=

# Supabase Auth (Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional but recommended: JWT Secret (Settings → API) — verifies tokens locally, skips Auth API RTT
SUPABASE_JWT_SECRET=

# Vite frontend (same URL/anon key; must be prefixed with VITE_)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=

# Owner email used by bands backfill (default tekumsceh@gmail.com)
OWNER_EMAIL=tekumsceh@gmail.com

# API
API_PORT=3001
API_HOST=127.0.0.1
NODE_ENV=production
# SERVE_STATIC=0
# Comma-separated browser origins allowed for CORS (defaults include PUBLIC_APP_URL + chabar.rs + localhost)
# CORS_ORIGINS=https://chabar.rs,https://www.chabar.rs

# Google Calendar sync (OAuth Web client — register BOTH redirects on the same client)
# Local:  http://localhost:3001/api/google/calendar/callback
# Live:   https://chabar.rs/api/google/calendar/callback
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3001/api/google/calendar/callback
PUBLIC_APP_URL=http://localhost:5173
# Required in production: long random string used to encrypt stored Google tokens
GOOGLE_TOKEN_ENC_KEY=
