# Local MySQL (used only for one-time migration from XAMPP)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ioorganize

# Supabase Postgres connection URI (Session pooler recommended)
DATABASE_URL=

# Supabase Auth (Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional but recommended: JWT Secret (Settings → API) — verifies tokens locally, skips Auth API RTT
SUPABASE_JWT_SECRET=

# Vite frontend (same URL/anon key; must be prefixed with VITE_)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=

# Owner email used by bands backfill (default tekumsceh@gmail.com)
OWNER_EMAIL=tekumsceh@gmail.com

# API
API_PORT=3001
API_HOST=127.0.0.1
NODE_ENV=production
# SERVE_STATIC=0
