# /var/www/ioorganize/.env on Hostinger VPS

NODE_ENV=production
API_PORT=3001
API_HOST=127.0.0.1
SERVE_STATIC=0

DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# Required for auth (copy from local .env / Supabase API settings)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=

# Optional on VPS (only needed for admin scripts, not runtime)
# SUPABASE_SERVICE_ROLE_KEY=
