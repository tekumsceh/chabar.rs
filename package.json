{
  "name": "chabar",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "node --watch server/index.js",
    "build": "vite build",
    "start": "node server/index.js",
    "preview": "vite preview --host 0.0.0.0",
    "db:setup": "node scripts/setup-db.js",
    "db:setup:supabase": "node scripts/setup-supabase.js",
    "db:migrate:supabase": "node scripts/migrate-mysql-to-supabase.js",
    "check": "node --check server/index.js && node --check server/auth.js && node --check server/googleCalendar.js && node --check server/rateLimit.js && node --check server/audit.js && node --check scripts/setup-db.js && node --check scripts/setup-supabase.js && node --check scripts/migrate-mysql-to-supabase.js && node --check scripts/migrate-bands-ownership.js",
    "db:migrate:comments-audit": "node scripts/apply-event-comments-audit.js",
    "db:migrate:invite-links": "node scripts/apply-band-invite-links.js",
    "db:migrate:notifications": "node scripts/apply-user-notifications.js",
    "db:migrate:expenses": "node scripts/apply-event-expenses.js",
    "db:migrate:bands": "node scripts/migrate-bands-ownership.js",
    "db:migrate:finance": "node scripts/migrate-member-finance.js",
    "deploy": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy.ps1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.7",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jose": "^6.2.3",
    "mysql2": "^3.15.3",
    "pg": "^8.22.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^7.2.7",
    "vite-plugin-pwa": "^1.3.0"
  }
}
